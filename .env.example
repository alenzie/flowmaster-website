# ─────────────────────────────────────────────
# FlowMaster Site — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# STRIPE
# Get from: https://dashboard.stripe.com → Developers → API Keys
# Use the "Publishable key" (starts with pk_test_ for test mode, pk_live_ for production)
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# SUPABASE
# Get from: https://supabase.com/dashboard → Your Project → Project Settings → API
# "Project URL" and "anon / public" key
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────
# PRODUCTION NOTE
# For GitHub Pages deployments these must also be set as
# GitHub Actions secrets in: Settings → Secrets and variables → Actions
# ─────────────────────────────────────────────
